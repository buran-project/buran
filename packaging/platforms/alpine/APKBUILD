# Reference APKBUILD for the Buran Application Server. CI-verified on every
# release (.github/workflows/release.yml builds it in a clean alpine
# container). For an aports submission: set a real maintainer, regenerate
# checksums (`abuild checksum`), and vendor crates if `options=net` is not
# acceptable at the time of submission.
#
# Maintainer: Buran Project <buran@example.invalid>
pkgname=buran
pkgver=0.1.0
pkgrel=0
pkgdesc="Buran universal application server"
url="https://github.com/buran-project/buran"
arch="all"
license="Apache-2.0"
makedepends="cargo rust"
subpackages="$pkgname-openrc"
source="$pkgname-$pkgver.tar.gz
	buran.initd
	buran.yaml
	"
# net: crates are fetched by cargo; !check: no test suite wired yet
options="net !check"

# One module subpackage per PHP branch of this aports release; the module
# binary name (buran-php84) is what `module:` in buran.yaml resolves to.
_phpvers="83 84 85"
for _v in $_phpvers; do
	subpackages="$subpackages $pkgname-php$_v"
	makedepends="$makedepends php$_v-dev php$_v-embed"
done

build() {
	cargo build --release --locked -p buran

	# libphp placement varies per version (libphp83.so vs php85/libphp.so);
	# derive link name, dir and rpath from the package contents — the same
	# derivation the official Docker images use.
	local v so libdir libname
	for v in $_phpvers; do
		so="/$(apk info -qL php$v-embed | grep '\.so$')"
		libdir="${so%/*}"
		libname="${so##*/}"
		libname="${libname#lib}"
		libname="${libname%.so}"
		BURAN_PHP_CONFIG="php-config$v" \
		BURAN_PHP_LIB="$libname" \
		BURAN_PHP_LIB_DIR="$libdir" \
		RUSTFLAGS="-C link-arg=-Wl,-rpath,$libdir" \
			cargo build --release --locked -p buran-php
		install -D target/release/buran-php "$builddir"/modules/buran-php$v
	done
}

package() {
	install -Dm755 target/release/buran "$pkgdir"/usr/sbin/buran
	install -Dm644 "$srcdir"/buran.yaml "$pkgdir"/etc/buran/buran.yaml
	install -Dm755 "$srcdir"/buran.initd "$pkgdir"/etc/init.d/buran
	install -dm755 "$pkgdir"/usr/lib/buran/modules
}

_php() {
	local v="${subpkgname##*php}"
	pkgdesc="$pkgdesc (PHP $v runtime module)"
	depends="$pkgname=$pkgver-r$pkgrel php$v-embed"
	install -Dm755 "$builddir"/modules/buran-php$v \
		"$subpkgdir"/usr/lib/buran/modules/buran-php$v
}
for _v in $_phpvers; do
	eval "php$_v() { _php; }"
done

# Regenerated by CI / `abuild checksum` — placeholder values here.
sha512sums="
0  buran-0.1.0.tar.gz
0  buran.initd
0  buran.yaml
"
